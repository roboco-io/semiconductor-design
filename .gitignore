# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Node / CDK
node_modules/
cdk.out/
*.tsbuildinfo
dist/

# Build artifacts (too large for git)
.cache/
build/
generated/
*.gds
*.gds.gz
*.lef
*.def
*.vcd
*.fst

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Local orchestrator state
~/.cache/semi-design/
traces/
local-sqlite/

# Plan subagent drafts — content is merged into the main plan; draft kept only locally
docs/superpowers/plans/drafts/

# Personal handoff file — never commit
.handoff.md

# Per-machine Claude Code overrides (settings.json은 팀 공유, .local.json은 개인용)
.claude/settings.local.json
.claude/settings.json.bak.*

# semi-run CLI runtime artifact (written by `init` to CWD for Makefile convenience)
.last-run-id

# KG smoke-mode scratch specs (written by scripts/kg/kg-f1-prebudget.sh on each run)
specs/_kg_*.yaml

# graphify evaluation & output (2026-04-22, commit policy = 옵션 A+)
# graph.json · GRAPH_REPORT.md · graph.html 은 커밋 (팀 공유 knowledge artifact).
# cache · intermediate(.graphify_*)만 무시.
tmp/graphify-eval/
build/graph/
graphify-out/cache/
graphify-out/.graphify_*
.graphify-cache/

# auto-gate 세대 임시/대용량 산출물 (재생성 가능)
experiments/*/t1/
experiments/*/candidates/*/art/
experiments/*/candidates/*/__pycache__/
experiments/*.log
