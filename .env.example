# AWS 배포 설정 템플릿.
# 이 파일을 `.env`로 복사해 실제 값을 채우세요. `.env`는 .gitignore로 커밋되지 않습니다
# (계정 ID 등 환경별 식별자를 public 저장소에 노출하지 않기 위함).
#
#   cp .env.example .env   # 그 후 아래 값을 채움
#
# CDK(cdk/bin/eda-flow.ts)가 synth 시 repo 루트의 .env를 자동 로드한다(dotenv).

CDK_DEFAULT_ACCOUNT=000000000000   # 12자리 AWS 계정 ID
CDK_DEFAULT_REGION=ap-northeast-2  # EdaFlowStack 배포 region
AWS_PROFILE=roboco                 # 로컬 AWS 프로필명 (aws CLI용)
